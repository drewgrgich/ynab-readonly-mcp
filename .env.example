# Copy this file to ".env" and fill in your real values.

# Required. Get a Personal Access Token at https://app.ynab.com/settings/developer
# This token is read from the environment and is never sent to the LLM.
YNAB_API_TOKEN=your-token-here

# Optional. Set a default budget so you don't have to pass a budget ID every time.
# Find the ID by running the ynab_list_budgets tool once. Leave unset to use
# YNAB's "last-used" budget.
# YNAB_BUDGET_ID=
